import type { Config, Context } from "@netlify/functions";
export default async(req:Request,_context:Context)=>{const u=new URL(req.url),currency=(u.searchParams.get("currency")||"").toUpperCase(),month=u.searchParams.get("month")||"";if(!/^[A-Z]{3}$/.test(currency)||!/^\d{4}-\d{2}$/.test(month))return Response.json({status:"error"},{status:400});if(currency==="USD")return Response.json({status:"ok",currency,month,points:[{day:1,value:1}]});const [y,m]=month.split("-").map(Number),from=`${month}-01`,to=new Date(Date.UTC(y,m,0)).toISOString().slice(0,10);try{const r=await fetch(`https://api.frankfurter.app/${from}..${to}?from=USD&to=${currency}`);if(!r.ok)return Response.json({status:"NA",currency,month,points:[]});const p=await r.json() as any;const points=Object.entries(p.rates||{}).map(([d,v]:any)=>({day:Number(String(d).slice(-2)),value:v[currency]})).filter((x:any)=>Number.isFinite(x.value));return Response.json({status:points.length?"ok":"NA",provider:"Frankfurter",currency,month,points});}catch{return Response.json({status:"NA",currency,month,points:[]})}};export const config:Config={path:"/api/fx",method:["GET"]};