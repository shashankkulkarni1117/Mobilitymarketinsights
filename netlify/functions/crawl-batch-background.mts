import type { Context } from "@netlify/functions";
import sources from "../../data/sources.json" with {type:"json"};import configs from "../../data/global-search-config.json" with {type:"json"};import { newsStore } from "./_shared/store.mts";import { searchGdelt } from "./_shared/free-search.mts";import { crawlSource } from "./_shared/direct-crawler.mts";
export default async(req:Request,_context:Context)=>{const u=new URL(req.url),region=u.searchParams.get("region")||"",month=u.searchParams.get("month")||"";if(!region||!/^\d{4}-\d{2}$/.test(month))throw new Error("region and month required");const store=newsStore();const q=await store.get("review-queue.json",{type:"json"}) as any;const items=[...(q?.items||[])];for(const s of (sources as any[]).filter(x=>String(x.region).toUpperCase()===region.toUpperCase())){try{items.push(...await crawlSource(s,month))}catch{}}for(const c of (configs as any[]).filter(x=>String(x.region).toUpperCase()===region.toUpperCase())){try{items.push(...await searchGdelt(c,month))}catch{}}const unique=[...new Map(items.map((x:any)=>[String(x.url||x.id).toLowerCase(),x])).values()].sort((a:any,b:any)=>String(b.date).localeCompare(String(a.date)));await store.setJSON("review-queue.json",{generatedAt:new Date().toISOString(),count:unique.length,items:unique});};